# ── Backend (FastAPI) ─────────────────────────────────────
# Required: Google Gemini API Key for AI Assistant
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Path to Firebase service account JSON (for local dev without Cloud Run)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ── Frontend (Vite / React) ───────────────────────────────
# Optional: Override API base URL in development
# Defaults to https://nexusdfi-backend-741401327113.us-central1.run.app in prod
VITE_API_URL=http://localhost:8000
